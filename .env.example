# JIRA Configuration
#
# NOTE: This file is OPTIONAL and mainly for testing/temporary use.
# For permanent setup, add these to your ~/.zshrc file instead:
#   export JIRA_API_TOKEN="your_token_here"
#
# If you use this .env file, you must run "source .env" before each use.

# Required: Your JIRA API token (create at: https://id.atlassian.com/manage-profile/security/api-tokens)
JIRA_API_TOKEN=your_jira_api_token_here

# Optional: Override default JIRA URL (defaults to https://jira.ops.expertcity.com)
# JIRA_URL=https://your-company.atlassian.net

# Optional: Override default project key (defaults to DATA)
# JIRA_PROJECT=YOUR_PROJECT_KEY
